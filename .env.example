# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" | "anthropic"
LLM_PROVIDER=openai
# Options (openai): gpt-4o  gpt-4o-mini
# Options (anthropic): claude-3-7-sonnet-20250219  claude-3-5-haiku-20241022
LLM_MODEL=gpt-4o

# ── Transcription Provider ────────────────────────────────────────────────────
# Options: "whisper_api" | "whisper_local" | "assemblyai" | "deepgram"
TRANSCRIPTION_PROVIDER=whisper_api

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# AssemblyAI (if TRANSCRIPTION_PROVIDER=assemblyai)
ASSEMBLYAI_API_KEY=

# Deepgram (if TRANSCRIPTION_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# ── Music Lookup APIs (optional — omit to skip that source) ───────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Discogs (requires: pip install discogs-client)
DISCOGS_TOKEN=

# SoundCloud (optional — get a client_id from https://developers.soundcloud.com/)
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# AudD audio fingerprinting (optional — https://audd.io, 500 free req/month)
AUDD_API_KEY=
